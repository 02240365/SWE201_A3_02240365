# -----------------------------------------------------------------------------
# Sample environment configuration.
#
# This Expo app reads the API base URL from src/config/index.ts. Plain Expo does
# not auto-read .env, so the actual value used by the app lives in that file
# (API_BASE_URL). The notes below show what to set for each run target.
#
# For a physical phone, use your computer's LAN IP (localhost will NOT work on
# a real device).
# -----------------------------------------------------------------------------

# Android emulator:           http://10.0.2.2:3001
# iOS simulator:              http://localhost:3001
# Physical device (your IP):  http://192.168.1.100:3001
API_BASE_URL=http://192.168.1.100:3001
